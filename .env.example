# Required
OPENAI_API_KEY=sk-...

# Optional overrides
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# Optional: enables shared/persistent embedding cache across restarts.
# If unset, falls back to a local on-disk cache under .cache/embeddings.
REDIS_URL=redis://localhost:6379/0

# Where Chroma persists its index and where repos get cloned to.
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_CACHE_DIR=./.cache/embeddings
