# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# EMBEDDING_MODEL runs locally via sentence-transformers (no API key needed --
# Anthropic doesn't offer an embeddings endpoint).
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHAT_MODEL=claude-opus-4-8

# Optional: enables shared/persistent embedding cache across restarts.
# If unset, falls back to a local on-disk cache under .cache/embeddings.
# Set this if running via `docker compose up` (which provides a redis
# service) or if you have Redis running locally -- leave unset otherwise.
# REDIS_URL=redis://localhost:6379/0

# Where Chroma persists its index and where repos get cloned to.
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_CACHE_DIR=./.cache/embeddings
